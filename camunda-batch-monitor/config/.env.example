# Camunda Configuration
CAMUNDA_URL=https://your-camunda-host:port # http://localhost:8080
CAMUNDA_USERNAME=your_username # demo
CAMUNDA_PASSWORD=your_password # demo

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN

# The processes to monitor, evaluated in priority order
PROCESS_KEYS=BatchProcess,PaymentProcess

# Process variables to extract and send with notifications (comma-separated, optional)
# Security Risk:: If Camunda processes store Personally Identifiable Information (PII) like
# names, emails, internal bearer tokens, or sensitive user data, mapping them via TRACKED_VARIABLES 
# will permanently leak those secrets onto the Google Chat platform (which exists on public servers outside your immediate control).
TRACKED_VARIABLES=processKey,jobId
